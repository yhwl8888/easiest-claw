# 统一文本行尾，避免 Windows / macOS / Linux 混用导致噪音 diff
* text=auto
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.json text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf
*.ps1 text eol=lf
*.nsh text eol=lf
.githooks/* text eol=lf
*.bat text eol=crlf
*.cmd text eol=crlf

# 常见二进制文件禁止文本转换
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.icns binary
*.webp binary
*.zip binary
*.exe binary
*.dll binary
*.node binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
